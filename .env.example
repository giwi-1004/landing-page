# Supabase — 실제 값은 .env.local 에만 두고, 이 파일에는 예시만 두세요 (커밋용).
# 대시보드: https://supabase.com/dashboard → Project Settings → API
#
# --- 키 분리 ---
# 서버 전용(비밀): NEXT_PUBLIC_ 붙이지 말 것
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#
# Publishable(공개) — 아래 A 또는 B
# A) NEXT_PUBLIC_ (빌드에 포함, 권장)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# B) 서버 전용 이름(런타임에 /api/lead-supabase-public 로 내려줌, NEXT_PUBLIC_ 없어도 됨)
# SUPABASE_ANON_KEY=
#
# DB: supabase/setup_lead_requests_full.sql 를 SQL Editor에서 한 번 실행
